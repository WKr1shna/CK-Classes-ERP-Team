# Server Environment Configuration Example

# Server Environment & Network
PORT=5050
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connection
MONGO_URI=mongodb://127.0.0.1:27017/ck_classes

# JWT Authentication & Cookie Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_COOKIE_NAME=ck_access_token
JWT_REFRESH_COOKIE_NAME=ck_refresh_token

# Cookie Domain/SameSite (Deployment - optional, only needed in production)
# COOKIE_DOMAIN: set ONLY if frontend & backend share a root domain, e.g. ".ckclasses.com"
#   (allows the cookie to be sent from app.ckclasses.com to api.ckclasses.com).
#   Leave blank for local dev, and leave blank if frontend/backend are on unrelated hosts
#   (e.g. two separate onrender.com subdomains) - use COOKIE_SAMESITE=none instead in that case.
# COOKIE_SAMESITE: "lax" (default, same-site or same-root-domain deployments) or "none"
#   (required for fully cross-site frontend/backend hosting; forces secure:true automatically).
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# SMTP Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password_here
SMTP_FROM=noreply@ckclasses.com

# Cloudinary Media Storage (Optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ImageKit Media Storage (Optional)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint

# AI Module Configuration (grok | gemini | openai | ollama)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
# OPENAI_API_KEY=your_openai_api_key_here
# OLLAMA_HOST=http://localhost:11434

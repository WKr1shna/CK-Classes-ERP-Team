<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="#ECECEC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Student Photo / Avatar Circle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="@color/background"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="#ECECEC"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvStudentAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="S"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Student ID -->
                <TextView
                    android:id="@+id/tvStudentId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CK20260021"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Full Name -->
                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="chirayu kailash poddar"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Email -->
                <TextView
                    android:id="@+id/tvStudentEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="saritapoddar41@gmail.com"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Status Pill Badge -->
            <TextView
                android:id="@+id/tvStudentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_primary"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Active"
                android:textColor="@color/status_present"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#F0F0F0" />

        <!-- Details Row: Class, Phone, Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Class Badge -->
            <TextView
                android:id="@+id/tvStudentClass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_primary"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Class 12 Science"
                android:textColor="@color/primary_light"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Phone Number -->
            <TextView
                android:id="@+id/tvStudentPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="📞 9978413139"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Action Buttons -->
            <ImageView
                android:id="@+id/btnViewStudent"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/text_secondary" />

            <ImageView
                android:id="@+id/btnEditStudent"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/ic_assignment"
                app:tint="@color/primary" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
